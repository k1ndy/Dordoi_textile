# ─────────────────────────────────────────────────────────────
#  Дордой Каталог — переменные окружения
#  Скопируйте этот файл в .env.local и заполните значения.
#  Сайт работает и БЕЗ Supabase (на демо-данных), но для
#  реального использования заполните блок Supabase.
# ─────────────────────────────────────────────────────────────

# Supabase — база данных, авторизация админа, хранилище фото
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role — ТОЛЬКО сервер (API). Никогда не отдавайте на клиент и не коммитьте!
SUPABASE_SERVICE_ROLE_KEY=

# Telegram-уведомления о новых заявках
# 1) Создайте бота через @BotFather → получите токен
# 2) Узнайте свой chat_id (напишите боту, затем https://api.telegram.org/bot<TOKEN>/getUpdates)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Публичные контакты (показываются на сайте; можно переопределить в админ-настройках)
NEXT_PUBLIC_WHATSAPP=+
NEXT_PUBLIC_TELEGRAM=
NEXT_PUBLIC_INSTAGRAM=

# Базовый URL сайта (для SEO / sitemap)
NEXT_PUBLIC_SITE_URL=https://example.com
